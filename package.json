{
  "name": "f2-chat-server",
  "version": "0.0.1",
  "description": "Large-scale Chat Backend with AI Bot Integration",
  "private": true,
  "main": "bin/www.js",
  "scripts": {
    "start:auth": "cross-env NODE_ENV=local node services/auth.js",
    "start:conn": "cross-env NODE_ENV=local node services/connection.js",
    "start:worker": "cross-env NODE_ENV=local node services/worker.js",
    "start:ai": "cross-env NODE_ENV=local node services/ai.js",
    "start:all": "npm run start:auth & npm run start:conn & npm run start:worker & npm run start:ai"
  },
  "dependencies": {
    "amqplib": "^0.10.9",
    "cookie-parser": "~1.4.4",
    "cross-env": "^10.1.0",
    "debug": "~2.6.9",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-errors": "~1.6.3",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "morgan": "~1.9.1",
    "pug": "^3.0.3",
    "socket.io": "^4.8.3"
  }
}
